# Compiled binaries — any file matching the module name or example directory name
# produced by `go build ./...` or `go build -o <name>`
/go-kitsune
/metrics
/benchcheck
testdata/bench/current.txt

# Example binaries. Use `go run ./examples/<name>` or the Taskfile targets
# rather than `go build`; if you do build manually, use `-o main` so this
# pattern covers the output.
examples/*/main
examples/*/*.exe

# Test cache and coverage output
*.test
*.out
coverage.html

# Benchmark profiles
*.prof
*.pprof
cpu.prof
mem.prof

# Go workspace file (optional local multi-module development)
go.work
go.work.sum

# OS artefacts
.DS_Store
Thumbs.db

# Editor artefacts
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary / scratch files
*.tmp
*.bak

# Claude Code
.claude

# Git worktrees
.worktrees/
