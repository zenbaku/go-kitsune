# Compiled binaries — any file matching the module name or example directory name
# produced by `go build ./...` or `go build -o <name>`
/go-kitsune
/metrics
/inspector

# Example binaries built in-place (e.g. `go build ./examples/scan`)
examples/*/main
examples/*/*.exe
# Examples with a standalone go.mod build a binary named after the directory.
examples/files/files
examples/http/http
examples/prometheus/prometheus
examples/redis/redis
examples/sqlite/sqlite
examples/websocket/websocket

# Test cache and coverage output
*.test
*.out
coverage.html

# Benchmark profiles
*.prof
*.pprof
cpu.prof
mem.prof

# Go workspace file (optional local multi-module development)
go.work
go.work.sum

# OS artefacts
.DS_Store
Thumbs.db

# Editor artefacts
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary / scratch files
*.tmp
*.bak
